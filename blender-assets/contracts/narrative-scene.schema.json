{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dead-reckoning.local/schemas/narrative-scene.schema.json",
  "title": "Dead Reckoning narrative place contract",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "label",
    "entity_type",
    "contract_status",
    "identity",
    "relationships",
    "chapter_logic",
    "visual_program",
    "evidence"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "label": { "type": "string" },
    "entity_type": {
      "enum": [
        "nested_landmark_compound",
        "kingdom_region_system",
        "island_town_system",
        "island_bridge_system",
        "moving_world_entity",
        "mountain_city_system",
        "vertical_political_world_structure",
        "mangrove_grove_network",
        "sky_archipelago_system",
        "city_landmark_event_system",
        "sea_train_route_network"
      ]
    },
    "contract_status": { "enum": ["research_hold", "ready_for_system_sketch", "ready_for_blender_blockout"] },
    "identity": {
      "type": "object",
      "required": ["anchor", "components"],
      "properties": {
        "anchor": { "type": "object" },
        "components": { "type": "array", "items": { "type": "object" } }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "type", "to"],
        "properties": {
          "from": { "type": "string" },
          "type": { "type": "string" },
          "to": { "type": "string" },
          "confidence": { "enum": ["canon", "cited_summary", "unresolved"] }
        }
      }
    },
    "chapter_logic": {
      "type": "object",
      "required": ["base_reveal_chapter", "temporal_variants", "event_scenes"],
      "properties": {
        "base_reveal_chapter": { "type": ["integer", "null"] },
        "temporal_variants": { "type": "array", "items": { "$ref": "#/$defs/state" } },
        "event_scenes": { "type": "array", "items": { "$ref": "#/$defs/event" } }
      }
    },
    "route_network": { "type": "object" },
    "coordinate_policy": { "type": "object" },
    "visual_program": { "type": "object" },
    "unresolved": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "object" } }
  },
  "$defs": {
    "state": {
      "type": "object",
      "required": ["id", "reveal_chapter", "state"],
      "properties": {
        "id": { "type": "string" },
        "reveal_chapter": { "type": ["integer", "null"] },
        "state": { "type": "string" },
        "verification": { "enum": ["verified", "chapter_to_verify"] }
      }
    },
    "event": {
      "type": "object",
      "required": ["id", "importance", "reveal_chapter", "landmark", "state_delta"],
      "properties": {
        "id": { "type": "string" },
        "importance": { "type": "integer", "minimum": 1, "maximum": 3 },
        "reveal_chapter": { "type": ["integer", "null"] },
        "landmark": { "type": "string" },
        "state_delta": { "type": "string" },
        "verification": { "enum": ["verified", "chapter_to_verify"] },
        "camera_cue": { "type": "string" },
        "fx": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
