{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dead-reckoning.local/schemas/east-blue-saga-simulation.schema.json",
  "title": "Grand Line saga simulation pack",
  "type": "object",
  "required": ["schema_version", "id", "arcs", "scenes", "runtime_policy", "future_milestones"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string"},
    "arcs": {"type": "array", "minItems": 1},
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "arc_id", "type", "priority", "readiness", "chapter_gate", "place", "duration_ms", "actors", "events"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["tableau", "encounter", "transition"]},
          "priority": {"enum": ["anchor", "supporting"]},
          "readiness": {"enum": ["runtime_ready", "art_partial", "research_hold"]},
          "duration_ms": {"type": "integer", "minimum": 1000},
          "actors": {"type": "array"},
          "events": {"type": "array"}
        }
      }
    },
    "runtime_policy": {"type": "object"},
    "future_milestones": {"type": "array"}
  }
}
