  "representation": "camera-facing-2d-atlas-with-authored-movement-and-3d-fx",
  "runtime_policy": {
    "backward_scrub": "Reset scene time, actor transforms, pose selection, effects, and landmark state deterministically.",
    "chapter_gate": "Never fetch a scene before a verified start chapter. research_hold scenes remain disabled.",
    "lod0": "Existing portrait bubble or icon.",
    "lod1": "Static atlas frame; at most three visible story beats.",
    "lod2": "One active 2D atlas simulation plus local 3D or shader effects.",
    "lod3": "Explicit inspect/replay using the same movement contract; optional sound later.",
    "max_active_close_scenes": 1,
    "max_distant_loops": 3,
    "missing_art": "Do not substitute rigid mannequins. Show a disabled story marker with missing_assets metadata.",
    "playback": "Play once on entering the active chapter window, hold the authored final frame, and allow explicit replay afterward.",
    "reduced_motion": "Use the final safe pose and suppress camera shake, rain motion, and repeated effects."
  },
