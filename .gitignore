/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Raw wiki response cache — a local accelerator, NOT a build artifact.
# Two reasons this must never be committed:
#   1. LICENSE: the cached action=parse responses contain full rendered article
#      HTML, i.e. CC-BY-SA article PROSE. Only FACTS may live in this repo.
#      The generated JSON below is facts-only and is safe to commit.
#   2. SIZE: ~18MB of HTML for ~250KB of extracted facts.
# Delete it freely; `python3 scripts/sync_wiki.py` rebuilds it in ~50 requests.
data/generated/_wiki_cache/

# NOTE: data/generated/*.json IS committed on purpose. The app reads committed
# JSON only and never fetches at request time. Do not ignore it.

# 18MB of raw wikitext responses — a re-run cache, not a build input.
data/generated/_wiki_cache/
__pycache__/
